# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── SendGrid ──────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.your-sendgrid-api-key
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
DEFAULT_FROM_NAME=Nomad For Life

# Optional: SendGrid webhook signing key (for /api/webhooks/sendgrid)
# SENDGRID_WEBHOOK_KEY=your-webhook-signing-key

# ── Application ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# Long random secret — protects /api/internal/* routes
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=replace-with-random-secret

# ── Queue tuning (optional) ───────────────────────────────────────────────────
# QUEUE_BATCH_SIZE=100
# QUEUE_MAX_RETRIES=3

# ── Webflow webhook ───────────────────────────────────────────────────────────
# Geheime sleutel die als ?secret= query-parameter aan de Webflow webhook-URL
# wordt toegevoegd. Genereer met: openssl rand -hex 32
# WEBFLOW_WEBHOOK_SECRET=replace-with-random-secret
